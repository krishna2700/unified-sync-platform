# ------------------------------------------------------------------
# Application
# ------------------------------------------------------------------
NODE_ENV=development
PORT=3000
LOG_LEVEL=info
# Comma-separated list of origins allowed to call the API
CORS_ORIGIN=http://localhost:3000
# Shared secret required in the `x-api-key` header for mutating/admin endpoints
ADMIN_API_KEY=change-me-local-dev-key
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# ------------------------------------------------------------------
# Database (Supabase Postgres)
# DATABASE_URL uses the pooled (pgbouncer, port 6543) connection for the app.
# DIRECT_URL uses the direct (port 5432) connection, required by Prisma Migrate.
# ------------------------------------------------------------------
DATABASE_URL="postgresql://postgres:[PASSWORD]@[HOST]:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres"

# ------------------------------------------------------------------
# Redis (BullMQ job queue). Free option: Upstash Redis (TLS) or local docker-compose redis.
# ------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# ------------------------------------------------------------------
# HubSpot (CRM provider) - Private App token from a free HubSpot Developer test account.
# Settings > Integrations > Private Apps > create app with crm.objects.contacts.read/write,
# crm.objects.deals.read/write, crm.schemas.contacts.read scopes.
# ------------------------------------------------------------------
HUBSPOT_ACCESS_TOKEN=replace-with-your-hubspot-private-app-token
HUBSPOT_API_BASE_URL=https://api.hubapi.com
HUBSPOT_WEBHOOK_CLIENT_SECRET=change-me

# ------------------------------------------------------------------
# Google Calendar (Calendar/Events provider) - OAuth2 client from Google Cloud Console
# with a refresh token obtained once via the offline consent flow (scripts/google-oauth-init.ts).
# ------------------------------------------------------------------
GOOGLE_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=change-me
GOOGLE_REDIRECT_URI=http://localhost:3000/oauth/google/callback
GOOGLE_REFRESH_TOKEN=change-me
GOOGLE_CALENDAR_ID=primary
GOOGLE_WEBHOOK_CHANNEL_TOKEN=change-me

# ------------------------------------------------------------------
# Stripe (Payment Processor provider) - test-mode secret key from a free Stripe account.
# ------------------------------------------------------------------
STRIPE_SECRET_KEY=replace-with-your-stripe-test-mode-secret-key
STRIPE_WEBHOOK_SECRET=replace-with-your-stripe-webhook-signing-secret

# ------------------------------------------------------------------
# Sync engine tuning
# ------------------------------------------------------------------
SYNC_CURSOR_STALE_AFTER_HOURS=24
SYNC_MAX_RETRY_ATTEMPTS=5
SYNC_RETRY_BASE_DELAY_MS=1000
SYNC_JOB_CONCURRENCY=3
# How often the background worker's scheduled "sync everything" tick fires (milliseconds).
SYNC_SCHEDULE_INTERVAL_MS=900000
