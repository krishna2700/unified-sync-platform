{
  "name": "unified-sync-platform",
  "version": "0.1.0",
  "private": true,
  "description": "Multi-provider synchronization pipeline and revenue metrics service (CRM, Payments, Calendar) built with Clean/Hexagonal architecture.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/api/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/api/server.js",
    "worker:dev": "tsx watch src/workers/sync-worker.ts",
    "worker:start": "node dist/workers/sync-worker.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration --pool=forks --poolOptions.forks.singleFork=true",
    "test:contract": "vitest run tests/contract",
    "test:architecture": "vitest run tests/architecture",
    "test:coverage": "vitest run --coverage",
    "arch:check": "depcruise --config .dependency-cruiser.cjs src",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "prisma:seed": "tsx prisma/seed.ts",
    "seed": "tsx scripts/seed.ts",
    "seed:hubspot": "tsx scripts/seed-hubspot.ts",
    "seed:google-calendar": "tsx scripts/seed-google-calendar.ts",
    "seed:stripe": "tsx scripts/seed-stripe.ts",
    "google:oauth-init": "tsx scripts/google-oauth-init.ts",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/helmet": "^13.0.1",
    "@fastify/rate-limit": "^10.2.1",
    "@fastify/swagger": "^9.4.0",
    "@fastify/swagger-ui": "^5.2.1",
    "@hubspot/api-client": "^14.0.1",
    "@prisma/client": "^6.1.0",
    "bullmq": "^5.34.0",
    "close-with-grace": "^2.2.0",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.0",
    "fastify-plugin": "^5.0.1",
    "googleapis": "^173.0.0",
    "ioredis": "^5.4.2",
    "p-limit": "^6.2.0",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0",
    "prom-client": "^15.1.3",
    "stripe": "^17.5.0",
    "ulid": "^2.3.0",
    "undici": "^7.2.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.2",
    "@typescript-eslint/eslint-plugin": "^8.18.1",
    "@typescript-eslint/parser": "^8.18.1",
    "@vitest/coverage-v8": "^2.1.8",
    "dependency-cruiser": "^16.9.0",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "fast-glob": "^3.3.3",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "light-my-request": "^6.5.0",
    "lint-staged": "^15.2.11",
    "prettier": "^3.4.2",
    "prisma": "^6.1.0",
    "testcontainers": "^10.16.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
